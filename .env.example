# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Aomi Runtime ─────────────────────────────────────────────────────────────
# Your Aomi API key (from aomi.dev dashboard)
AOMI_API_KEY=
# Aomi backend base URL — leave as default unless self-hosting
AOMI_BASE_URL=https://api.aomi.dev
# App name your fanforge plugin is registered under in Aomi
AOMI_APP=fanforge

# ── Zora Protocol ────────────────────────────────────────────────────────────
# Optional — all Zora reads work unauthenticated at lower rate limits
ZORA_API_KEY=

# ── Supabase (fan missions + reward distribution state) ───────────────────────
# Create a free project at supabase.com
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── IPFS (coin metadata upload for coin launch) ───────────────────────────────
# Required for coin launch. Free tier at pinata.cloud — create a JWT API key.
PINATA_JWT=

# ── Base Chain RPC (for direct on-chain reads if needed) ──────────────────────
# Optional — Zora API covers most holder data
BASE_RPC_URL=https://mainnet.base.org
